# ─── Aleo Network ────────────────────────────────────────────────────────────
ALEO_NODE_URL=https://api.explorer.provable.com/v1
ALEO_NETWORK=testnet

# Provable v2 API — used by tally engine to find cast_vote transactions by operator address
ALEO_API_V2_URL=https://api.provable.com/v2

# ─── Operator Keypair ─────────────────────────────────────────────────────────
# Used to: publish create_scoped_snapshot on-chain + decrypt OperatorVote records
# Generate a fresh keypair: leo account new
# IMPORTANT: The operator address must match the address used when creating polls.
#            Each poll locks its operator at creation time.
OPERATOR_PRIVATE_KEY=APrivateKey1...
OPERATOR_VIEW_KEY=AViewKey1...
OPERATOR_ADDRESS=aleo1...

# ─── Issuer Keypair ───────────────────────────────────────────────────────────
# Used for legacy server-side credential issuance (/verify endpoint).
# For the recommended flow (/verify/credential-params), the user's wallet signs instead.
# Can be the same as the operator keypair for simplicity.
ALEO_ISSUER_PRIVATE_KEY=APrivateKey1...

# ─── EVM Requirement Checks ───────────────────────────────────────────────────
# Required for: TOKEN_BALANCE, NFT_OWNERSHIP, ONCHAIN_ACTIVITY, DOMAIN_OWNERSHIP, ALLOWLIST
# Get a free key at: https://dashboard.alchemy.com
ALCHEMY_API_KEY=your_alchemy_api_key

# ─── Twitter / X ─────────────────────────────────────────────────────────────
# Required for: X_FOLLOW requirement type
# Bearer token: https://developer.twitter.com/en/portal/dashboard
# OAuth keys: register app at developer.twitter.com, set callback to APP_URL/api/auth/twitter/callback
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTERAPI_IO_KEY=your_twitterapi_io_key   # alternative follow-check API (free tier)
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret

# ─── Discord ─────────────────────────────────────────────────────────────────
# Required for: DISCORD_MEMBER, DISCORD_ROLE requirement types
# Bot token: https://discord.com/developers/applications → Bot → Token
# OAuth keys: OAuth2 → Client ID/Secret, add callback APP_URL/api/auth/discord/callback
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Required for: GITHUB_ACCOUNT requirement type
# Register OAuth app: https://github.com/settings/developers
# Callback URL: APP_URL/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Required for: TELEGRAM_MEMBER requirement type
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username   # without @

# ─── Pinata IPFS ──────────────────────────────────────────────────────────────
# Optional — community configs and poll metadata are stored locally if not set.
# Recommended for production: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=your_pinata_jwt_token
PINATA_GATEWAY=your-gateway-subdomain   # e.g. "beige-quiet-bear-123" (no https://)

# ─── App ──────────────────────────────────────────────────────────────────────
# Frontend URL — must match registered OAuth callback base URL
APP_URL=http://localhost:5173
PORT=3001
