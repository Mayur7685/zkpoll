# ─── Aleo Network ────────────────────────────────────────────────────────────
VITE_ALEO_NODE_URL=https://api.explorer.provable.com/v1
VITE_ALEO_NETWORK=testnet

# ─── Verifier Backend ─────────────────────────────────────────────────────────
# Local: http://localhost:3001
# Live:  https://zkpoll-verifier.onrender.com
VITE_VERIFIER_URL=http://localhost:3001

# ─── Operator Address ─────────────────────────────────────────────────────────
# Public address of the tally operator keypair.
# Must match OPERATOR_ADDRESS in verifier/.env.
# Passed as the `operator` input to cast_vote — OperatorVote records are encrypted to this address.
VITE_OPERATOR_ADDRESS=aleo1...
