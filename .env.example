# Issuer account — used by the verifier service to call credential_issue.aleo
# KEEP PRIVATE — never commit the real value
ISSUER_PRIVATE_KEY=APrivateKey1...
ISSUER_VIEW_KEY=AViewKey1...
ISSUER_ADDRESS=aleo1...

# Operator account — used to call snapshot_tally.aleo
OPERATOR_PRIVATE_KEY=APrivateKey1...
OPERATOR_VIEW_KEY=AViewKey1...
OPERATOR_ADDRESS=aleo1...

# Aleo network
ALEO_NETWORK=testnet
ALEO_NODE_URL=https://api.explorer.provable.com/v1
